{
    "name": "marcosdipaolo/router",
    "description": "A PHP Router package",
    "type": "library",
    "keywords": ["php","router"],
    "license": "MIT",
    "authors": [
        {
            "name": "Marcos Di Paolo",
            "email": "marcosdipaolo@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "marcosdipaolo/container": "^1.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.12",
        "rector/rector": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MDP\\": "src/",
            "MDP\\Test\\": "test/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "scripts": {
        "test": "phpunit test/",
        "analyze": "phpstan analyze",
        "rector": "rector process src/",
        "rector-dry": "rector process src/ --dry-run",
        "check": [
            "@analyze",
            "@test"
        ]
    }
}
